{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Coding-Autopilot-System/cas-evals/schemas/evaluation-result.schema.json",
  "title": "CAS Evaluation Suite Result",
  "type": "object",
  "required": ["schemaVersion", "suiteId", "results", "summary"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "suiteId": { "type": "string", "minLength": 1 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["schemaVersion", "evaluatorVersion", "caseId", "kind", "correlationId", "fixtureDigest", "passed", "metrics"]
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed"]
    }
  }
}
